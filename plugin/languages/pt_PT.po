#: core/form.php:117
#, php-format
msgid ""
"Dear %s, thank you for getting in touch. We have received your message and "
"will be in touch with you shortly. Below you will find a copy of your "
"message for your records."
msgstr ""
"Caro/a %s, obrigado/a por entrar em contacto. Recebemos a sua mensagem e "
"entraremos em contacto consigo em breve. Em baixo encontra uma cópia da sua "
"mensagem para que possa consultar mais tarde."

#: core/form.php:124
msgid "Thank you for reaching out. We'll be in touch soon."
msgstr "Obrigado pela sua mensagem. Entraremos em breve em contacto consigo."

#: core/form.php:126
msgid "A copy of your message has been sent to your email address."
msgstr "Foi enviada uma cópia da sua mensagem para o seu endereço de email."

